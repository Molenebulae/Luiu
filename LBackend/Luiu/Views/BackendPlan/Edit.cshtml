@model Luiu.Models.CTripPlanWrap

@{
    ViewData["Title"] = "Edit";
}

<h4>修改旅遊行程規劃</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @*有其他不想讓使用者改但存檔需要的欄位都要隱藏*@
            <input type="hidden" name="TripId" value="@Model.TripId" />
            <input type="hidden" asp-for="Trip.OwnerId" />
            <input type="hidden" asp-for="Trip.CreateAt" />
            <div class="form-group">
                <label asp-for="TripName" class="control-label"></label>
                <input asp-for="TripName" class="form-control" />
                <span asp-validation-for="TripName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PrivacyStatus" class="control-label"></label>
                <div class="mt-2">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" asp-for="PrivacyStatus" value="1" id="privacyYes">
                            <label class="form-check-label" for="privacyYes">是</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" asp-for="PrivacyStatus" value="0" id="privacyNo">
                                <label class="form-check-label" for="privacyNo">否</label>
                            </div>
                        </div>
                        <span asp-validation-for="PrivacyStatus" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="IsSuggest" class="control-label"></label>
                        <div class="mt-2">
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="Trip.IsSuggest" value="true" id="SuggestYes">
                                    <label class="form-check-label" for="SuggestYes">是</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" asp-for="Trip.IsSuggest" value="false" id="SuggestNo">
                                        <label class="form-check-label" for="SuggestNo">否</label>
                                    </div>
                                </div>
                                <span asp-validation-for="PrivacyStatus" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="ShortCode" class="control-label"></label>
                                <input asp-for="ShortCode" class="form-control" readonly/>
                                <span asp-validation-for="ShortCode" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="OwnerName" class="control-label"></label>
                                <input asp-for="OwnerName" class="form-control" readonly/>
                                <span asp-validation-for="OwnerName" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ListId" class="control-label"></label>
                                @* 使用 Select 標籤，資料來源是剛才在 Controller 設定的 ViewBag *@
                                <select asp-for="ListId" class="form-control"
                                        asp-items="ViewBag.PackingListItems">
                                    <option value="">-- 請選擇打包清單 --</option>
                                </select>
                                <span asp-validation-for="ListId" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="StartDate" class="control-label"></label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="EndDate" class="control-label"></label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                            <br>
                            <div class="form-group">
                                <input type="submit" value="送出並修改" class="btn btn-primary" />
                            </div>
                        </form>
                    </div>
                </div>

                <div>
                    <a asp-action="TripList">取消新增修改</a>
                </div>

                @section Scripts {
                    @{
                        await Html.RenderPartialAsync("_ValidationScriptsPartial");
                    }
                }
