@using System.Reflection
@using System.ComponentModel.DataAnnotations
@using Luiu.Helpers
@using Luiu.Enums
@using Luiu.ViewModels
@model IEnumerable<Luiu.Models.CMemberWrap>

@{
    ViewData["Title"] = "List";
    var vm = ViewBag.vm as CMemberSearchViewModel;
    int totalPage = (int)Math.Ceiling((double)vm.TotalCount / vm.PageSize);

    // 設定顯示按鈕
    int maxButtons = 5;
    int startPage = vm.Page - (maxButtons / 2);
    int endPage = vm.Page + (maxButtons / 2);

    // 處理左邊界
    if (startPage <= 0)
    {
        endPage -= (startPage - 1);
        startPage = 1;
    }

    // 處理右邊界
    if (endPage > totalPage)
    {
        endPage = totalPage;
        if (endPage - maxButtons + 1 > 0)
            startPage = endPage - maxButtons + 1;
        else
            startPage = 1;
    }

    int startItem = (vm.Page - 1) * vm.PageSize + 1;
    int endItem = Math.Min(vm.Page * vm.PageSize, vm.TotalCount);
}

<div class="main-breadcrumb my-3 position-relative">
    <div class="flex-shrink-0">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-double-slash">
                <li class="breadcrumb-item"><a href="javascript:void(0)">會員管理</a></li>
                <li class="breadcrumb-item active" aria-current="page">會員資料</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <!-- header -->
            @using (Html.BeginForm("List", "Member", FormMethod.Get))
            {
                <div class="card-header flex-wrap gap-4">
                    <h4 class="card-title">
                        會員資料
                    </h4>

                    <div class="d-flex gap-3">
                        <div class="form-icon right">
                            <input class="form-control" id="search-input" placeholder="Search..." type="text" name="search">
                            <button type="submit" style="border:none; background:none; position:absolute; right:10px; top:50%; transform:translateY(-50%);">
                                <i class="ri-search-2-line search-icon"></i>
                            </button>
                        </div>

                        <input type="hidden" name="Category" id="searchCategory" value="name" />

                        <div class="dropdown">
                            <button aria-expanded="false" class="btn btn-light dropdown-toggle"
                                    data-bs-toggle="dropdown" type="button" id="search-type-btn">
                                <i class="ri-user-3-line me-2">
                                </i>
                                名字
                            </button>
                            <ul class="dropdown-menu">

                                <li class="dropdown-item search-type-option" data-type="Name">
                                    <i class="ri-user-3-line me-2">
                                    </i>
                                    名字
                                </li>

                                <li class="dropdown-item search-type-option" data-type="Email">
                                    <i class="ri-mail-send-line me-2">
                                    </i>
                                    @Html.DisplayNameFor(model => model.Email)
                                </li>

                                <li class="dropdown-item search-type-option" data-type="Phone">
                                    <i class="ri-user-add-line me-2">
                                    </i>
                                    @Html.DisplayNameFor(model => model.Phone)
                                </li>
                            </ul>
                        </div>

                        <!-- Add New Exam Button -->
                        <a asp-action="Create" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-1">
                            </i>
                            新增會員
                        </a>
                    </div>
                </div>
            }
            <!-- body -->
            <div class="card-body">
                <div class="table-box table-responsive">
                    <table class="table table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th>
                                    序
                                </th>
                                <th>
                                    會員
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.Gender)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.Email)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.Phone)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.Birthday)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.CreateDate)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.LastLoginTime)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.Status)
                                </th>
                                <th>
                                    Action
                                </th>
                            </tr>
                        </thead>

                        <tbody>
                            @{
                                int count = startItem;
                                @foreach (var item in Model)
                                {
                                    
                                    <tr class="@(item.IsDelete ? "opacity-50" : "")">
                                        <td>
                                            @count
                                        </td>
                                        <td class="d-flex align-items-center gap-3">
                                            <img alt="Avatar 1" class="avatar-md rounded-pill" src="@item.DisplayIconUrl">
                                            <div>
                                                <h6 class="mb-1">
                                                    @Html.DisplayFor(modelItem => item.Name)
                                                </h6>
                                                <p class="fs-12 mb-0 text-muted">
                                                    Customer ID:
                                                    <span class="fw-semibold">
                                                        @Html.DisplayFor(modelItem => item.UserId)
                                                    </span>
                                                </p>
                                            </div>
                                        </td>
                                        <td>
                                            @item.Gender.GetDisplayName()
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Email)
                                        </td>
                                        <td>
                                            @item.Phone.ToPhoneFormat()
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Birthday)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.CreateDate)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.LastLoginTime)
                                        </td>
                                        <td>
                                            <span class="badge @item.Status.GetBadgeClass()">
                                                @item.Status.GetDisplayName()
                                            </span>
                                        </td>
                                        <td>
                                            <a asp-controller="Member" asp-action="Edit" asp-route-id="@item.MemberId"
                                               class="btn btn-light-primary icon-btn-sm">
                                                <i class="bi bi-pencil-square">
                                                </i>
                                            </a>
                                            @if (!item.IsDelete)
                                            {
                                                <a asp-controller="Member" asp-action="Delete" asp-route-id="@item.MemberId"
                                                   class="btn btn-light-danger icon-btn-sm" onclick="return confirm('確定要刪除嗎?')">
                                                    <i class="ri-delete-bin-line">
                                                    </i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                    count++;
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap gap-3 align-items-center mt-5">
                    <div class="fw-medium">
                        Showing @startItem - @endItem of @vm.TotalCount Entries
                    </div>
                    <div class="ms-auto">
                        <nav aria-label="Page navigation example">
                            <ul class="pagination pagination-primary mb-0">
                                @* 上一頁 *@
                                <li class="page-item @(vm.Page == 1 ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("List", new { Category = vm.Category, Search = vm.Search, Page = vm.Page - 1 })">
                                        <i class="ri-arrow-left-s-line fw-semibold">
                                        </i>
                                    </a>
                                </li>

                                @* 頁碼清單 *@
                                @for(int i=startPage; i<= endPage; i++)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action("List", new { Category = vm.Category, Search = vm.Search, Page = i})">
                                            @i
                                        </a>
                                    </li>
                                    
                                }

                                @* 下一頁 *@
                                <li class="page-item @(vm.Page == totalPage ? "disabled" : "")">
                                    <a class="page-link" href="@Url.Action("List", new { Category = vm.Category, Search = vm.Search, Page = vm.Page + 1 })">
                                        <i class="ri-arrow-right-s-line fw-semibold">
                                        </i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
            <!-- body end -->
        </div>
    </div>
</div>

@section scripts {
    <script src="~/js/member.js"></script>
}