@model Luiu.Models.CViolationRuleWrap

@{
    ViewData["Title"] = "Edit";
}

<div class="main-breadcrumb my-3 position-relative">
    <div class="flex-shrink-0">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-double-slash">
                <li class="breadcrumb-item"><a href="javascript:void(0)">檢舉管理</a></li>
                <li class="breadcrumb-item active" aria-current="page">違規規則</li>
                <li class="breadcrumb-item active" aria-current="page">編輯規則</li>
            </ol>
        </nav>
    </div>
</div>

<form asp-action="Edit">
    <div class="row">
        <div class="col">
            <div class="card">
                <div class="card-body">
                    <div class="row g-5">
                        <input type="hidden" name="RuleId" value="@Model.RuleId" />

                        <div class="col-12">
                            <label asp-for="Title" class="form-label"></label> :
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="RuleType" class="control-label"></label> :
                            <select asp-for="RuleType" class="form-select"
                                    asp-items='@(ViewBag.TypeItems as IEnumerable<SelectListItem>)'>
                                <option value="">-- 請選擇分類 --</option>
                            </select>
                        </div>

                        <div class="col-xl-6">
                            <label asp-for="Severity" class="control-label"></label> :
                            <select asp-for="Severity" class="form-select">
                                <option value="1">★</option>
                                <option value="2">★★</option>
                                <option value="3">★★★</option>
                                <option value="4">★★★★</option>
                                <option value="5">★★★★★</option>
                            </select>
                        </div>
                        <div class="col-xl-6">
                            <label asp-for="IsActivate" class="control-label"></label> :
                            <div class="d-flex flex-wrap gap-2">
                                <div>
                                    <input asp-for="IsActivate" type="radio" class="btn-check" id="private" value="false" autocomplete="off">
                                    <label class="btn btn-light-info" for="private">關閉</label>
                                </div>
                                <div>
                                    <input asp-for="IsActivate" type="radio" class="btn-check" id="public" value="true" autocomplete="off">
                                    <label class="btn btn-light-info" for="public">開啟</label>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="control-label"></label> :
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="DefaultAction" class="control-label"></label> :
                            <input asp-for="DefaultAction" class="form-control" />
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-3 justify-content-end mb-5">
            <a asp-action="List" class="btn btn-light">取消修改</a>
            <button class="btn btn-primary" type="submit">
                送出修改
            </button>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
