@using System.Diagnostics
@model IEnumerable<Luiu.Models.CViolationRuleWrap>

@{
    ViewData["Title"] = "List";
    var categoryList = new List<string>();
}



<div class="main-breadcrumb my-3 position-relative">
    <div class="flex-shrink-0">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-double-slash">
                <li class="breadcrumb-item"><a href="javascript:void(0)">檢舉管理</a></li>
                <li class="breadcrumb-item active" aria-current="page">違規規則</li>
            </ol>
        </nav>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h4>
            違規規則列表
        </h4>
        <div class="d-flex flex-wrap gap-3 ms-auto">
            <div class="form-icon">
                <input class="form-control form-control-icon" id="firstNameLayout4"
                       placeholder="Search Here ..." required="" type="text" />
                <i class="ri-search-2-line text-muted">
                </i>
            </div>
            <!-- Add New Exam Button -->
            <button class="btn btn-primary" data-bs-target="#createExamModal" data-bs-toggle="modal">
                <i class="bi bi-plus-lg me-1">
                </i>
                新增規則
            </button>
        </div>
    </div>

    <div class="card-body">
        @* 標題 *@
        <div class="card-header bg-light py-3 g-0">
            <div class="row w-100 fw-bold">
                <div class="col-3">@Html.DisplayNameFor(model => model.Title)</div>
                <div class="col-4">@Html.DisplayNameFor(model => model.Description)</div>
                <div class="col-1">@Html.DisplayNameFor(model => model.DefaultAction)</div>
                <div class="col-1 text-center">@Html.DisplayNameFor(model => model.Severity)</div>
                <div class="col-1 text-center">@Html.DisplayNameFor(model => model.UpdatedAt)</div>
                <div class="col-1 text-center">@Html.DisplayNameFor(model => model.IsActivate)</div>
                <div class="col-1 text-center">操作</div>
            </div>
        </div>

        @* 手風琴內容 *@
        <div class="accordion accordion-icon-none" id="demo_accordion_main_07">
            @{
                int i = 0;
                var groupData = Model.GroupBy(r => r.RuleType);  // 分組

                foreach (var group in groupData)
                {
                    i++;
                    categoryList.Add(group.Key);
                    string collapseId = "collapse_item_" + i;
                    <div class="accordion-item">
                        @* 標題 *@
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId" aria-expanded="true"
                                    aria-controls="demo_accorsdion_item_71">
                                <div class="d-flex justify-content-between w-100">
                                    <div class="d-flex align-items-center gap-1">
                                        <i class="bi bi-chevron-right accordion-arrow"></i>
                                        <span class="fs-6">@group.Key</span>
                                    </div>

                                    <div class="d-flex align-items-center gap-4">
                                        <div>
                                            <span class="badge rounded-pill bg-success-subtle text-success fs-6">
                                                @group.Count(r => r.IsActivate)
                                                條啟用中
                                            </span>
                                        </div>
                                        <div class="vr h-100"></div>
                                        <div>
                                            <span class="badge rounded-pill bg-light-subtle text-body fs-6">@group.Count() 條規則</span>
                                        </div>
                                    </div>
                                </div>
                            </button>
                        </h2>

                        @* 內容 *@
                        <div id="@collapseId" class="accordion-collapse collapse @(i == 1 ? "show" : "")" " data-bs-parent="#demo_accordion_main_07">
                            @foreach (var rule in group)
                            {
                                <div class="accordion-body">
                                    <div class="row w-100 align-items-center ">

                                        <div class="col-3" style="padding-left: 4rem;">@Html.DisplayFor(modelItem => rule.Title)</div>
                                        <div class="col-4">@Html.DisplayFor(modelItem => rule.Description)</div>
                                        <div class="col-1">@Html.DisplayFor(modelItem => rule.DefaultAction)</div>
                                        <div class="col-1 text-center">
                                            <div class="d-flex justify-content-center">
                                                @for (int s = 1; s <= 5; s++)
                                                {
                                                    <i class="bi bi-star-fill @(s <= rule.Severity ? "text-warning" : "text-light")" style="font-size: 0.65rem;"></i>
                                                }
                                            </div>
                                        </div>
                                        <div class="col-1 text-center">@Html.DisplayFor(modelItem => rule.UpdatedAt)</div>
                                        <div class="col-1 text-center">
                                            <div class="form-check form-switch d-inline-block">
                                                <input class="form-check-input" type="checkbox" @(rule.IsActivate ? "checked" : "")>
                                            </div>
                                        </div>

                                        <div class="col-1 text-center">
                                            <a asp-controller="ViolationRule" asp-action="Edit" asp-route-id="@rule.RuleId"
                                               class="btn btn-light-primary icon-btn-sm">
                                                <i class="bi bi-pencil-square">
                                                </i>
                                            </a>
                                            <a asp-controller="ViolationRule" asp-action="Delete" asp-route-id="@rule.RuleId"
                                               class="btn btn-light-danger icon-btn-sm" onclick="return confirm('確定要刪除嗎?')">
                                                <i class="ri-delete-bin-line">
                                                </i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }

                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@{
    if (!categoryList.Any())
    {
        categoryList.Add("一般規則");
    }
    var syncTypeItems = categoryList.Select(t => new SelectListItem
    {
        Value = t,
        Text = t,
    });
    Debug.WriteLine($"[List] syncTypeItems: {syncTypeItems}");
}
<partial name="_CreateRule"
         model="new CViolationRuleWrap()"
         view-data='@new ViewDataDictionary(ViewData) { { "TypeItems", syncTypeItems } }' /></partial>

@section Styles {
    <link href="~/css/violationRule.css" rel="stylesheet" />
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}