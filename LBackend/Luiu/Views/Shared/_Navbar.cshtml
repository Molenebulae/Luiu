@{
}
<!-- Begin Header -->
<header class="app-header" id="appHeader">
    <div class="container-fluid w-100">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-inline-flex align-items-center gap-2">
                <a class="align-items-end logo-main d-none me-5" href="index.html">
                    <img alt="Dark Logo" class="logo-dark" height="35" src="assets/images/logo-md.png" width="34" />
                    <h3 class="text-body-emphasis fw-bolder mb-0 ms-1">
                        LUIU
                    </h3>
                </a>

                <button aria-label="Toggle Menu" class="horizontal-toggle btn header-btn d-none" id="toggleHorizontal"
                        type="button">
                    <i class="ri-menu-2-line header-icon">
                    </i>
                </button>

            </div>
            <div class="flex-shrink-0 d-flex align-items-center gap-4">
                <div class="d-flex gap-2 align-items-center">
                    <div class="dropdown pe-dropdown-mega d-none d-md-block">
                        <button aria-expanded="false" aria-label="Notifications" class="btn header-btn"
                                data-bs-toggle="dropdown" type="button">
                            <i class="bi bi-bell">
                            </i>
                            <div class="icon-dot">
                            </div>
                        </button>
                        <div class="dropdown-menu dropdown-mega-md header-dropdown-menu pe-noti-dropdown-menu p-0">
                            <div class="p-3 border-bottom">
                                <h6 class="d-flex align-items-center mb-0">
                                    Notification
                                </h6>
                            </div>

                        </div>
                    </div>
                    <button class="btn header-btn d-block d-md-none" data-bs-target="#searchModal"
                            data-bs-toggle="modal" type="button">
                        <i class="ri-search-line">
                        </i>
                    </button>
                    <button aria-controls="offcanvasRight" aria-label="Settings"
                            class="btn header-btn d-none d-md-block" data-bs-target="#offcanvasRight"
                            data-bs-toggle="offcanvas" type="button">
                        <i class="bi bi-gear">
                        </i>
                    </button>
                </div>
                <div class="dropdown pe-dropdown-mega d-none d-md-block">
                    <button aria-expanded="false" class="header-profile-btn btn gap-1 text-start"
                            data-bs-toggle="dropdown" type="button">
                        <div class="d-none d-xl-block pe-2">
                            <span class="d-block mb-0 fs-12 fw-semibold">
                                Name
                            </span>
                            <span class="d-block mb-0 fs-10 text-muted">
                                email@gmail.com
                            </span>
                        </div>
                        <span class="header-btn btn position-relative">
                            <img alt="Avatar Image" class="img-fluid rounded-circle"
                                 src="assets/images/avatar/avatar-3.jpg" />
                        </span>
                    </button>
                    <div class="dropdown-menu dropdown-mega-sm header-dropdown-menu p-3">
                        <div class="border-bottom pb-2 mb-2 d-flex align-items-center gap-2">
                            <img alt="Avatar Image" class="avatar-md" src="assets/images/avatar/avatar-3.jpg" />
                            <div>
                                <a href="javascript:void(0)">
                                    <h6 class="mb-0 lh-base">
                                        Name
                                    </h6>
                                </a>
                                <p class="mb-0 fs-13 text-muted">
                                    email@gmail.com
                                </p>
                            </div>
                        </div>
                        <ul class="list-unstyled mb-1 border-bottom pb-1">
                            <li>
                                <a class="dropdown-item" href="pages-profile.html">
                                    <i class="bi bi-person me-2">
                                    </i>
                                    View Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="pages-profile.html">
                                    <i class="bi bi-gear me-2">
                                    </i>
                                    Settings
                                </a>
                            </li>
                        </ul>
                        <ul class="list-unstyled mb-0">
                            <li>
                                <a class="dropdown-item" href="auth-signout.html">
                                    <i class="bi bi-box-arrow-right me-2">
                                    </i>
                                    Sign Out
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
<!-- END Header -->